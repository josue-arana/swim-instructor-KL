<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="#top" aria-label="Katherine Lopez home">
      <span class="brand-mark" aria-hidden="true">KL</span>
      <span class="brand-copy">
        <strong>Katherine Lopez</strong>
        <small>Red Cross WSI Certified</small>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#top">Home</a>
      <a href="#accordion">About</a>
      <a href="#lessons">Lessons</a>
      <a href="#service-area">Areas</a>
      <a href="#contact">Contact</a>
    </nav>

    <a class="button button-small header-cta" href="#contact">Request Lessons</a>

    <details class="mobile-menu" data-mobile-menu>
      <summary
        aria-controls="mobile-navigation"
        aria-expanded="false"
        aria-label="Open navigation menu"
        data-menu-button
      >
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <nav class="mobile-nav" id="mobile-navigation" aria-label="Mobile navigation" data-mobile-nav>
        <a href="#top">Home</a>
        <a href="#accordion">About</a>
        <a href="#lessons">Lessons</a>
        <a href="#service-area">Areas</a>
        <a href="#contact">Contact</a>
        <a class="button" href="#contact">Request Lessons</a>
      </nav>
    </details>
  </div>
</header>

<script>
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const menuButton = document.querySelector('[data-menu-button]');
  const mobileLinks = document.querySelectorAll('[data-mobile-nav] a');

  if (mobileMenu instanceof HTMLDetailsElement && menuButton instanceof HTMLElement) {
    const syncMenuState = () => {
      menuButton.setAttribute('aria-expanded', mobileMenu.open ? 'true' : 'false');
    };

    const closeMenu = () => {
      mobileMenu.open = false;
      syncMenuState();
    };

    syncMenuState();
    mobileMenu.addEventListener('toggle', syncMenuState);

    mobileLinks.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    mobileMenu.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
        menuButton.focus();
      }
    });
  }
</script>
