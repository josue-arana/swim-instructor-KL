---
import fs from 'node:fs';
import path from 'node:path';

const preferredHeroImage = '/images/kl_profile2.PNG';
const fallbackHeroImage = '/images/kl_profile2.PNG';
const preferredHeroFile = path.join(process.cwd(), 'public', 'images', 'kl_profile2.PNG');
const fallbackHeroFile = path.join(process.cwd(), 'public', 'images', 'kl_profile2.PNG');
const heroImageSrc = fs.existsSync(preferredHeroFile)
  ? preferredHeroImage
  : fs.existsSync(fallbackHeroFile)
    ? fallbackHeroImage
    : null;
---
<section class="hero" id="top" aria-labelledby="hero-title">
  <div class="container hero-shell">
    <div class="hero-layout">
      <div class="hero-copy">
        <p class="eyebrow">Red Cross WSI Certified</p>
        <h1 id="hero-title"><span>Katherine</span><span>Lopez</span></h1>
        <p class="hero-standfirst">Private swim instruction for kids and adults</p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button" href="#contact">Request Lessons</a>
        </div>
      </div>

      <figure class="portrait-frame">
        {heroImageSrc ? (
          <img src={heroImageSrc} alt="Portrait of Katherine Lopez, Red Cross WSI certified swim instructor" loading="eager" />
        ) : (
          <div class="portrait-placeholder" role="img" aria-label="Katherine profile photo placeholder">
            <span>Katherine profile photo placeholder</span>
          </div>
        )}
      </figure>
    </div>

    <div class="hero-meta" aria-label="Service and trust highlights">
      <p>Serving Montgomery County, Prince George's County, Howard County, and the Baltimore area.</p>
    </div>
  </div>
</section>
