---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import AccordionSection from '../components/AccordionSection.astro';
import LessonHighlights from '../components/LessonHighlights.astro';
import ServiceArea from '../components/ServiceArea.astro';
import TestimonialsPreview from '../components/TestimonialsPreview.astro';
import SchedulingSection from '../components/SchedulingSection.astro';
import AiAssistantSection from '../components/AiAssistantSection.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const showSchedulingSection = false;
const showAiAssistantSection = false;
---
<BaseLayout>
  <Header />
  <main id="main-content">
    <Hero />
    <AccordionSection />
    <LessonHighlights />
    <ServiceArea />
    <TestimonialsPreview />
    {showSchedulingSection && <SchedulingSection />}
    {showAiAssistantSection && <AiAssistantSection />}
    <ContactForm />
  </main>
  <Footer />
</BaseLayout>
